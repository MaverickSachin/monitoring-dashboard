# Copy to .env.local and adjust. Never commit real secrets.
# These are server-only (read in lib/env.ts) — do NOT prefix with NEXT_PUBLIC_.

# Data source backing the dashboard: "mock" (default) or "api".
PIPELINE_DATA_SOURCE=mock

# REST API integration (used only when PIPELINE_DATA_SOURCE=api).
# Backend-agnostic — point it at the existing Flask service.
PIPELINE_API_BASE_URL=https://pipeline-api.internal
PIPELINE_API_RUNS_PATH=/audit_data

# Gateway identity headers (service account / app identifiers).
PIPELINE_API_USER_ID=
PIPELINE_API_APP_NAME=
PIPELINE_API_APP_PATH=

# Optional bearer token.
PIPELINE_API_TOKEN=
PIPELINE_API_DAYS=20

# TLS for internal certs: trust the CA at the runtime, never disable verification.
# NODE_EXTRA_CA_CERTS=/path/to/internal-ca.pem
